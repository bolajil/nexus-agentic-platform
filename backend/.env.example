# ── NEXUS Platform — Environment Variables ────────────────────────────────────
# Copy to .env and fill in your values.

# REQUIRED ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# APP ──────────────────────────────────────────────────────────────────────────
APP_NAME=nexus-platform
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS ─────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3002,http://localhost:3000

# REDIS ────────────────────────────────────────────────────────────────────────
# Falls back to in-memory store if Redis is unavailable
REDIS_URL=redis://localhost:6379

# CHROMADB ─────────────────────────────────────────────────────────────────────
# Falls back to in-memory ChromaDB if server is unavailable
CHROMA_HOST=localhost
CHROMA_PORT=8000

# OPENTELEMETRY ────────────────────────────────────────────────────────────────
# Optional — set to your collector endpoint
OTLP_ENDPOINT=http://localhost:4317

# LLM SETTINGS ─────────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# ZOO.DEV TEXT-TO-CAD ─────────────────────────────────────────────────────────
# Optional — enables AI-powered CAD generation from natural language
# Get API key: https://zoo.dev/account/api-tokens
# Pricing: $0.50/min, 20 free minutes/month
ZOO_API_KEY=
ZOO_API_URL=https://api.zoo.dev
ZOO_TIMEOUT_SECONDS=120
ZOO_MAX_RETRIES=3
