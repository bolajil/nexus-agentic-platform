# ── NEXUS Platform — Root Environment Variables ─────────────────────────────
# Copy to .env and fill in your values before running docker compose
#
# SECURITY: Never commit .env files with real keys!
# The .gitignore already excludes .env files.

# REQUIRED ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# OPTIONAL — Zoo.dev Text-to-CAD ──────────────────────────────────────────────
# Get API key: https://zoo.dev/account/api-tokens
ZOO_API_KEY=
